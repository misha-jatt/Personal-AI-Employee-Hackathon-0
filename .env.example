# =============================================================================
# AI Employee Vault — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# --- Core Settings ---
VAULT_PATH=D:/AI_Employee_Vault
DRY_RUN=true
LOG_LEVEL=INFO

# --- Watcher Settings ---
WATCHER_CHECK_INTERVAL=5
INBOX_WATCH_PATH=D:/AI_Employee_Vault/Inbox
